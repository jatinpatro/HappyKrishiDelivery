PORT=3000
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=30d
DB_PATH=./data/happykrishi.db

# Firebase (paste full JSON as single line)
FIREBASE_SERVICE_ACCOUNT_JSON=

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_OTP_TEMPLATE=otp_verification

# SMS OTP
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=orders@happykrishi.com
FROM_NAME=HappyKrishi Delivery

# Razorpay (scaffold — fill when ready)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Business defaults (overridden by app_config table)
MIN_WALLET_BALANCE=100
MIN_ORDER_AMOUNT=50
FREE_DELIVERY_ABOVE=500
BASE_DELIVERY_CHARGE=30
DELIVERY_CHARGE_PER_KM=5
GEOFENCE_RADIUS_M=500

# Admin seed (first run only)
ADMIN_SEED_PHONE=9999999999
ADMIN_SEED_EMAIL=admin@happykrishi.com
ADMIN_SEED_PASSWORD=Admin@123
